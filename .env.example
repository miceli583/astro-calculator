# Optional: override the path where Swiss Ephemeris data files live.
# Defaults to ./ephemeris (auto-populated by `npm run ephe:download`).
# EPHEMERIS_PATH=./ephemeris

# Optional: public base URL used in OpenAPI spec (no trailing slash).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Sentry (error monitoring — DSN is safe to expose client-side; set in Vercel)
NEXT_PUBLIC_SENTRY_DSN=
# Only needed for source-map upload during production builds (CI/Vercel)
SENTRY_ORG=miracle-mind
SENTRY_PROJECT=astro-calculator
SENTRY_AUTH_TOKEN=
